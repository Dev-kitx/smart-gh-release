{
  "name": "smart-gh-release",
  "version": "1.0.0",
  "description": "Feature-rich GitHub release action with auto-versioning, smart changelog, checksums, and more",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "ncc build src/index.js --license licenses.txt -o dist",
    "test": "node --test src/__tests__/**/*.test.js",
    "lint": "eslint src/",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/glob": "^0.5.0",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.2",
    "eslint": "^10.1.0"
  }
}
