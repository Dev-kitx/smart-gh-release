{
  "name": "smart-gh-release",
  "version": "0.6.7",
  "description": "Feature-rich GitHub release action with auto-versioning, smart changelog, checksums, and more",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "ncc build src/index.js --license licenses.txt -o dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "prepare": "npm run build && npm run setup-hooks",
    "setup-hooks": "cp .githooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@actions/glob": "^0.7.0",
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.44.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "vitest": "^4.1.2"
  }
}
